STORELEADS_API_KEY=your-storeleads-api-key
APOLLO_API_KEY=your-apollo-api-key
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_CHANNEL_ID=your-slack-channel-id
INSTANTLY_CAMPAIGN_ID=your-instantly-campaign-id
INSTANTLY_API_KEY=your-instantly-api-key
# Optional alias supported by the app if your deploy platform already uses this name:
INSTANTLY_AI=your-instantly-api-key
HEYREACH_API_KEY=your-heyreach-api-key
HEYREACH_CAMPAIGN_ID=your-heyreach-campaign-id
# Optional override if HeyReach changes the public add-to-campaign endpoint:
# HEYREACH_ADD_LEADS_TO_CAMPAIGN_URL=https://api.heyreach.io/api/public/campaign/AddLeadsToCampaignV2
DAILY_NEW_LEAD_LIMIT=15
ENABLE_WEEKDAY_ONLY_IMPORTS=true
STATE_BACKEND=local
# To persist processed domains and daily counts in GitHub instead of Render local disk:
# STATE_BACKEND=github
# GITHUB_STATE_TOKEN=your-github-token-with-contents-write-access
# GITHUB_STATE_REPO=david-anata/Lead-scraper
# GITHUB_STATE_BRANCH=state
# GITHUB_STATE_BASE_BRANCH=main
# GITHUB_STATE_PROCESSED_DOMAINS_PATH=state/processed_domains.csv
# GITHUB_STATE_DAILY_IMPORTS_PATH=state/daily_import_counts.csv
# GITHUB_STATE_HEYREACH_LEADS_PATH=state/heyreach_processed_leads.csv
# Optional local file overrides for temporary scheduler state:
# PROCESSED_DOMAINS_FILE=processed_domains.csv
# DAILY_IMPORT_LOG_FILE=daily_import_counts.csv
# HEYREACH_PROCESSED_LEADS_FILE=heyreach_processed_leads.csv

# Sales support agent
CLICKUP_API_TOKEN=your-clickup-api-token
# Optional alias supported by the sales support agent if your environment already uses this name:
CLICKUP_API_KEY=your-clickup-api-token
CLICKUP_LIST_ID=your-clickup-list-id
SALES_AGENT_INTERNAL_API_KEY=your-internal-api-key
SALES_AGENT_DB_URL=sqlite:///runtime/sales_support_agent.sqlite3
CLICKUP_DISCOVERY_SAMPLE_SIZE=10
CLICKUP_DISCOVERY_SNAPSHOT_PATH=runtime/clickup_schema_snapshot.json
CLICKUP_USE_DUE_DATE_FOR_FOLLOW_UP=false
# Map ClickUp assignee ids or names to Slack user ids.
SLACK_AE_MAP_JSON={"clickup-user-id":"slack-user-id"}
# Optional managed field overrides if your ClickUp CRM already has these fields.
# CLICKUP_NEXT_FOLLOW_UP_FIELD_ID=
# CLICKUP_COMMUNICATION_SUMMARY_FIELD_ID=
# CLICKUP_LAST_MEETING_OUTCOME_FIELD_ID=
# CLICKUP_RECOMMENDED_NEXT_ACTION_FIELD_ID=
# CLICKUP_LAST_MEANINGFUL_TOUCH_FIELD_ID=
# CLICKUP_LAST_OUTBOUND_FIELD_ID=
# CLICKUP_LAST_INBOUND_FIELD_ID=
INSTANTLY_WEBHOOK_SECRET=your-instantly-webhook-secret
INSTANTLY_WEBHOOK_SECRET_HEADER=X-Instantly-Webhook-Secret
INSTANTLY_WEBHOOK_ALLOWED_EVENT_TYPES=email_sent,reply_received,lead_meeting_booked,lead_meeting_completed,lead_interested,lead_not_interested,lead_neutral

# QuickBooks Online OAuth 2.0
# Credentials from https://developer.intuit.com → your app → Keys & credentials
QB_CLIENT_ID=your-qbo-client-id
QB_CLIENT_SECRET=your-qbo-client-secret
# Must match the redirect URI registered in the Intuit developer portal exactly.
QB_REDIRECT_URI=https://agent.anatainc.com/callback
# Random 32+ character secret used to encrypt stored QB tokens at rest.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production — omitting causes tokens to be stored in plaintext (warning logged).
QB_TOKEN_SECRET=change-me-generate-with-secrets-token-hex-32
